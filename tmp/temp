import os
import base64
from cryptography.fernet import Fernet
from azure.identity import ManagedIdentityCredential
from azure.keyvault.secrets import SecretClient

def encrypt_sc_idp_token(tkn):
    sc_idp_key_secret_name = "sc-idp-token-key"
    key = pull_secret_from_kv(sc_idp_key_secret_name).encode('utf-8')
    # key = base64.b64encode(key)
    f = Fernet(key)
    tkn_bytes = tkn.encode()
    encrypted_tkn_bytes = f.encrypt(tkn_bytes)
    encrypted_tkn = encrypted_tkn_bytes.decode()
    filename = "/.sc-idp_token.enc"
    if os.path.exists(filename):
        try:
            os.remove(filename)
        except PermissionError:
            print(f"Permission denied: Unable to remove '{filename}'.")
    try:
        with open(filename, "w") as file:
            file.write(encrypted_tkn)
    except PermissionError:
        print(f"Permission denied: Unable to create '{filename}'.")
    print ("sc-idp token encrypted and stored in file")

def decrypt_sc_idp_token():
    sc_idp_key_secret_name = "sc-idp-token-key"
    key = pull_secret_from_kv(sc_idp_key_secret_name).encode()
    f = Fernet(key)
    filename = "/.sc-idp_token.enc"
    encrypted_tkn = ""
    try:
        with open(filename, "r") as file:
            encrypted_tkn=file.read()
    except FileNotFoundError:
        print(f"Error: The file '{filename}' was not found.")
    decrypted_tkn_bytes = f.decrypt(encrypted_tkn)
    decrypted_tkn = decrypted_tkn_bytes.decode()
    # print(decrypted_tkn) #for testing
    return decrypted_tkn

def pull_secret_from_kv(secret_name):
    client_id = ""
    client_id_filename = "/.clientidname.txt"
    with open(client_id_filename, "r") as file:
        client_id=file.read().strip()
    kv_name = ""
    kv_filename = "/.kvname.txt"
    with open(kv_filename, "r") as file:
        kv_name=file.read().strip()
    kv_vault_url = f"https://{kv_name}.vault.azure.net/"
    credential = ManagedIdentityCredential(client_id=client_id)
    client = SecretClient(vault_url=kv_vault_url, credential=credential)
    secret_value_obj = client.get_secret(secret_name)
    secret_value = secret_value_obj.value
    # print(secret_value) #for testing
    return secret_value

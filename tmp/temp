import configIA
import time
import jwt  # PyJWT library
import requests
import json
from sc_idp_token_enc import encrypt_sc_idp_token
import logging

logger = logging.getLogger("ragBackend.get_token")

def get_token_from_sc_idp():
    start = time.time()
    config = configIA.configure()
    jwt_private_key = config.jwt_private_key
    # Define endpoint and client id
    authn_endpoint = config.authn_endpoint
    client_id = config.client_id

    # Prepare timestamp
    current_timestamp = time.time()

    # Set payload headers
    headers = {
        'alg': 'RS256',
        'typ': 'JWT'
    }

    # Set payload for JWT
    jwt_payload = {
        "aud": authn_endpoint,
        "iss": client_id,
        "sub": client_id,
        "exp": current_timestamp + 60 * 30,
        "iat": current_timestamp,
        "jti": str(current_timestamp)
    }

    # Generate JWT
    signed_token = jwt.encode(jwt_payload, jwt_private_key, algorithm="RS256", headers=headers)
    # print(signed_token)
    signed_token = signed_token.decode('utf-8') if type(signed_token)==type(bytes()) else signed_token
    # print(signed_token)
    logger.debug(f"Generated signed JWT | duration={time.time() - start:.2f}s")
    start = time.time()
    # Authenticate and get access token
    auth_payload = f'grant_type=client_credentials&client_id={client_id}&client_assertion_type=urn%3Aietf%3Aparams%3Aoauth%3Aclient-assertion-type%3Ajwt-bearer&client_assertion={signed_token}'
    headers = {
      'Content-Type': 'application/x-www-form-urlencoded'
    }
    response = requests.request("POST", authn_endpoint, headers=headers, data=auth_payload, verify=False)
    logger.debug(f"Obtained SC-IDP token | duration={time.time() - start:.2f}s")
    start = time.time()
    response_dict = json.loads(response.text)
    logger.debug(f"Token expires in {response_dict['expires_in']}s")
    access_token = response_dict['access_token']
    encrypt_sc_idp_token(access_token)
    logger.debug(f"Encrypted SC-IDP token | duration={time.time() - start:.2f}s")
    return access_token
